    if [ -d /home/dwemer/omnivoice-tts/venv ]; then
        OMNIVOICE_SKIP_DEPENDENCIES=1 OMNIVOICE_SKIP_DOCTOR=1 /home/dwemer/omnivoice-tts/ddistro_install.sh
