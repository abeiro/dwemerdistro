#!/bin/bash

# Simplified color palette - only red and green for specific cases
GREEN='\033[0;32m'
RED='\033[1;31m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Store password for sudo commands
PASSWORD="dwemer"
UPDATE_HERIKA=1
UPDATE_STOBE=1
UPDATE_DIALECTIC=1
DIALECTIC_UPDATE_FAILED=0
COMPONENT_UPDATE_FAILED=0

# Helper function for section headers
print_header() {
    local title="$1"
    local branch=""
    
    # Check if second parameter (branch) is provided
    if [ ! -z "$2" ]; then
        branch=" ($2)"
    fi
    
    printf "\n${BOLD}-------------------------------------------------------${NC}\n"
    printf "${BOLD} %s%s ${NC}\n" "$title" "$branch"
    printf "${BOLD}-------------------------------------------------------${NC}\n"
}

# Helper function for completion messages
print_success() {
    printf "${GREEN}[SUCCESS] %s${NC}\n" "$1"
}

print_warning() {
    printf "${RED}[WARNING] %s${NC}\n" "$1"
}

normalize_stobe_repo_path() {
    local canonical_path="/var/www/html/StobeServer"
    local legacy_path=""

    for legacy_path in /var/www/html/stobeserver /var/www/html/stoberser; do
        if [ -d "$legacy_path/.git" ] && [ ! -d "$canonical_path/.git" ]; then
            print_warning "Found legacy StobeServer path at $legacy_path. Migrating to $canonical_path."
            rm -rf "$canonical_path"
            if ! mv "$legacy_path" "$canonical_path"; then
                print_warning "Failed to migrate legacy StobeServer path from $legacy_path."
                return 1
            fi
            print_success "Migrated StobeServer repository to canonical path."
        fi
    done

    return 0
}

ensure_stobe_repo_exists() {
    local target_branch="${1:-stobe}"
    local repo_path="/var/www/html/StobeServer"

    mkdir -p /var/www/html >/dev/null 2>&1 || true

    if ! normalize_stobe_repo_path; then
        return 1
    fi

    if [ ! -d "$repo_path/.git" ]; then
        print_header "INSTALLING STOBE SERVER" "$target_branch"
        cd /var/www/html || {
            print_warning "Base path /var/www/html is missing and could not be accessed."
            return 1
        }

        rm -rf "$repo_path"
        printf ">> Cloning StobeServer repository...\n"
        if git clone -b "$target_branch" https://github.com/Dwemer-Dynamics/StobeServer.git StobeServer; then
            STOBE_INITIAL_INSTALL=1
        else
            print_warning "Failed to clone StobeServer repository."
            return 1
        fi
    fi

    if [ ! -d "$repo_path/.git" ]; then
        print_warning "StobeServer repository is not ready at $repo_path."
        return 1
    fi

    return 0
}

clear_stobe_initial_logs() {
    local log_dir="/var/www/html/StobeServer/log"
    local stobe_import_log="$log_dir/stobe_import.log"
    local stobeserver_log="$log_dir/stobeserver.log"

    mkdir -p "$log_dir" >/dev/null 2>&1 || true

    if ! : > "$stobe_import_log"; then
        print_warning "Failed to clear $stobe_import_log during initial install."
        return 1
    fi

    if ! : > "$stobeserver_log"; then
        print_warning "Failed to clear $stobeserver_log during initial install."
        return 1
    fi

    print_success "Cleared initial Stobe log files."
    return 0
}

ensure_stobe_database() {
    local schema_path="/var/www/html/StobeServer/data/schema.sql"
    local db_exists=""
    local schema_ready=""

    print_header "ENSURING STOBE DATABASE"

    if [ ! -d /var/www/html/StobeServer ]; then
        print_warning "StobeServer directory not found; skipping database provisioning."
        return 1
    fi

    export PGPASSWORD=dwemer

    db_exists=$(psql -h localhost -U dwemer -tAc "SELECT 1 FROM pg_database WHERE datname = 'stobe' LIMIT 1" 2>/dev/null | tr -d '[:space:]')
    if [ "$db_exists" != "1" ]; then
        printf ">> Creating stobe database...\n"
        if ! createdb -h localhost -U dwemer stobe >/dev/null 2>&1; then
            print_warning "Failed to create stobe database."
            unset PGPASSWORD
            return 1
        fi
        print_success "Database 'stobe' created."
    else
        print_success "Database 'stobe' already exists."
    fi

    if [ ! -f "$schema_path" ]; then
        print_warning "Stobe schema file missing: $schema_path"
        unset PGPASSWORD
        return 1
    fi

    schema_ready=$(psql -h localhost -U dwemer -d stobe -tAc "SELECT 1 FROM information_schema.tables WHERE table_schema='public' AND table_name='general_settings' LIMIT 1" 2>/dev/null | tr -d '[:space:]')
    if [ "$schema_ready" != "1" ]; then
        printf ">> Applying Stobe schema...\n"
        if ! psql -h localhost -U dwemer -d stobe -f "$schema_path" >/dev/null 2>&1; then
            print_warning "Failed to apply Stobe schema."
            unset PGPASSWORD
            return 1
        fi
        print_success "Stobe schema applied."
    else
        print_success "Stobe schema already present."
    fi

    if [ -f /var/www/html/StobeServer/debug/run_db_updates.php ]; then
        local stobe_db_update_log="/var/www/html/StobeServer/log/db_update_runner.log"
        local stobe_db_update_tmp="/tmp/stobe_db_update_runner.out"
        printf ">> Running Stobe DB updates...\n"
        if ! php /var/www/html/StobeServer/debug/run_db_updates.php >"$stobe_db_update_tmp" 2>&1; then
            mkdir -p /var/www/html/StobeServer/log >/dev/null 2>&1 || true
            {
                printf "\n[%s] update_gws: run_db_updates.php failed\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
                cat "$stobe_db_update_tmp"
            } >> "$stobe_db_update_log"
            print_warning "StobeServer DB update trigger failed. See $stobe_db_update_log"
            rm -f "$stobe_db_update_tmp"
            unset PGPASSWORD
            return 1
        fi
        rm -f "$stobe_db_update_tmp"
        print_success "Stobe DB updates completed."
    else
        print_warning "Stobe DB update runner not found; skipping."
    fi

    unset PGPASSWORD
    return 0
}

restore_dialectic_runtime_state() {
    local backup_path="$1"
    local repo_path="/var/www/html/DialecticServer"
    local relative_path=""

    for relative_path in conf/conf.php conf/character_map.json; do
        if [ -e "$backup_path/$relative_path" ]; then
            mkdir -p "$repo_path/$(dirname "$relative_path")"
            cp -a "$backup_path/$relative_path" "$repo_path/$relative_path"
        fi
    done

    for relative_path in uploads data/voices soundcache log; do
        if [ -d "$backup_path/$relative_path" ]; then
            mkdir -p "$repo_path/$relative_path"
            cp -a "$backup_path/$relative_path/." "$repo_path/$relative_path/"
        fi
    done

    if [ -d "$backup_path/conf" ]; then
        find "$backup_path/conf" -maxdepth 1 -type f -name 'conf_*.php' -exec cp -a {} "$repo_path/conf/" \;
    fi
}

ensure_dialectic_runtime_permissions() {
    local helper="/usr/local/bin/ensure_dialectic_runtime_permissions"

    if [ ! -x "$helper" ]; then
        helper="/home/dwemer/dwemerdistro/bin/ensure_dialectic_runtime_permissions"
    fi

    if [ ! -x "$helper" ]; then
        print_warning "DialecticServer permission helper is unavailable."
        return 1
    fi

    if ! echo "$PASSWORD" | sudo -S "$helper" /var/www/html/DialecticServer; then
        print_warning "DialecticServer runtime permission repair failed."
        return 1
    fi

    return 0
}

ensure_dialectic_repo_exists() {
    local target_branch="${1:-dialectic}"
    local repo_path="/var/www/html/DialecticServer"
    local backup_path=""

    mkdir -p /var/www/html >/dev/null 2>&1 || true

    if [ -d "$repo_path" ] && [ ! -d "$repo_path/.git" ]; then
        backup_path="${repo_path}.pre-git-$(date -u '+%Y%m%d%H%M%S')"
        print_warning "Found a manually deployed DialecticServer. Moving it to $backup_path before installing the managed repository."
        if ! mv "$repo_path" "$backup_path"; then
            print_warning "Failed to back up the existing DialecticServer directory."
            return 1
        fi
    fi

    if [ ! -d "$repo_path/.git" ]; then
        print_header "INSTALLING DIALECTIC SERVER" "$target_branch"
        cd /var/www/html || return 1
        if ! git clone -b "$target_branch" https://github.com/Dwemer-Dynamics/DialecticServer.git DialecticServer; then
            print_warning "Failed to clone DialecticServer repository."
            rm -rf "$repo_path"
            if [ -n "$backup_path" ] && [ -d "$backup_path" ]; then
                mv "$backup_path" "$repo_path"
                print_warning "Restored the previous manually deployed DialecticServer."
            fi
            return 1
        fi
        DIALECTIC_INITIAL_INSTALL=1

        if [ -n "$backup_path" ] && [ -d "$backup_path" ]; then
            restore_dialectic_runtime_state "$backup_path"
            print_success "Restored DialecticServer configuration, voices, uploads, cache, and logs. Backup retained at $backup_path"
        fi
    fi

    [ -d "$repo_path/.git" ]
}

ensure_dialectic_database() {
    local server_root="/var/www/html/DialecticServer"
    local baseline="$server_root/data/database_default.sql"
    local utf8_migration="$server_root/tools/migrate-dialectic-db-utf8-wsl.sh"
    local db_exists=""
    local db_encoding=""
    local schema_ready=""
    local bootstrap_output="/tmp/dialectic_database_bootstrap.out"

    print_header "ENSURING DIALECTIC DATABASE"
    if [ ! -d "$server_root" ]; then
        print_warning "DialecticServer directory not found; skipping database provisioning."
        return 1
    fi

    if ! pg_isready -d template1 -q; then
        printf ">> PostgreSQL is not running; starting it now...\n"
        echo "$PASSWORD" | sudo -S /etc/init.d/postgresql start >"$bootstrap_output" 2>&1 || true
        local postgres_ready=0
        local attempt
        for attempt in {1..15}; do
            if pg_isready -d template1 -q; then
                postgres_ready=1
                break
            fi
            sleep 1
        done
        if [ "$postgres_ready" -ne 1 ]; then
            mkdir -p "$server_root/log" >/dev/null 2>&1 || true
            cp "$bootstrap_output" "$server_root/log/db_update_runner.log" 2>/dev/null || true
            print_warning "PostgreSQL did not start. See $server_root/log/db_update_runner.log"
            return 1
        fi
    fi

    export PGPASSWORD=dwemer
    : > "$bootstrap_output"
    if ! db_exists=$(psql -h localhost -U dwemer -d dwemer -X -tAc "SELECT 1 FROM pg_database WHERE datname = 'dialectic' LIMIT 1" 2>>"$bootstrap_output"); then
        printf '\nApplication database catalog probe failed; trying the PostgreSQL service account.\n' >> "$bootstrap_output"
        if ! db_exists=$(echo "$PASSWORD" | sudo -S -u postgres psql -d template1 -X -tAc "SELECT 1 FROM pg_database WHERE datname = 'dialectic' LIMIT 1" 2>>"$bootstrap_output"); then
            mkdir -p "$server_root/log" >/dev/null 2>&1 || true
            cp "$bootstrap_output" "$server_root/log/db_update_runner.log" 2>/dev/null || true
            print_warning "Failed to inspect the Dialectic database. See $server_root/log/db_update_runner.log"
            tail -n 8 "$bootstrap_output" | sed 's/^/  /'
            unset PGPASSWORD
            return 1
        fi
    fi
    db_exists=$(printf '%s' "$db_exists" | tr -d '[:space:]')
    if [ "$db_exists" != "1" ]; then
        printf ">> Creating dialectic database...\n"
        if ! echo "$PASSWORD" | sudo -S -u postgres createdb --maintenance-db=template1 --owner=dwemer --encoding=UTF8 --locale=C --template=template0 dialectic >"$bootstrap_output" 2>&1; then
            mkdir -p "$server_root/log" >/dev/null 2>&1 || true
            cp "$bootstrap_output" "$server_root/log/db_update_runner.log" 2>/dev/null || true
            print_warning "Failed to create dialectic database. See $server_root/log/db_update_runner.log"
            unset PGPASSWORD
            return 1
        fi
    fi

    : > "$bootstrap_output"
    if ! db_encoding=$(psql -h localhost -U dwemer -d dwemer -X -tAc "SELECT pg_encoding_to_char(encoding) FROM pg_database WHERE datname = 'dialectic'" 2>>"$bootstrap_output"); then
        printf '\nApplication database encoding probe failed; trying the PostgreSQL service account.\n' >> "$bootstrap_output"
        if ! db_encoding=$(echo "$PASSWORD" | sudo -S -u postgres psql -d template1 -X -tAc "SELECT pg_encoding_to_char(encoding) FROM pg_database WHERE datname = 'dialectic'" 2>>"$bootstrap_output"); then
            mkdir -p "$server_root/log" >/dev/null 2>&1 || true
            cp "$bootstrap_output" "$server_root/log/db_update_runner.log" 2>/dev/null || true
            print_warning "Failed to inspect the Dialectic database encoding. See $server_root/log/db_update_runner.log"
            tail -n 8 "$bootstrap_output" | sed 's/^/  /'
            unset PGPASSWORD
            return 1
        fi
    fi
    db_encoding=$(printf '%s' "$db_encoding" | tr -d '[:space:]')
    if [ "$db_encoding" = "SQL_ASCII" ]; then
        if [ ! -f "$utf8_migration" ]; then
            print_warning "Dialectic database uses SQL_ASCII, but the UTF-8 migration tool is missing: $utf8_migration"
            unset PGPASSWORD
            return 1
        fi

        printf ">> Migrating the existing Dialectic database from SQL_ASCII to UTF8...\n"
        if ! echo "$PASSWORD" | sudo -S bash "$utf8_migration" >"$bootstrap_output" 2>&1; then
            mkdir -p "$server_root/log" >/dev/null 2>&1 || true
            cp "$bootstrap_output" "$server_root/log/db_utf8_migration.log" 2>/dev/null || true
            print_warning "Dialectic UTF-8 migration failed. The original database was retained. See $server_root/log/db_utf8_migration.log"
            unset PGPASSWORD
            return 1
        fi

        db_encoding=$(echo "$PASSWORD" | sudo -S -u postgres psql -d template1 -X -tAc "SELECT pg_encoding_to_char(encoding) FROM pg_database WHERE datname = 'dialectic'" 2>/dev/null | tr -d '[:space:]')
        if [ "$db_encoding" != "UTF8" ]; then
            print_warning "Dialectic database migration completed without producing UTF8 (reported encoding: ${db_encoding:-unknown})."
            unset PGPASSWORD
            return 1
        fi

        rm -f "$bootstrap_output"
        print_success "Dialectic database migrated to UTF8. A rollback database and safety dump were retained."
    elif [ "$db_encoding" != "UTF8" ]; then
        print_warning "Dialectic database uses unsupported encoding '${db_encoding:-unknown}'."
        unset PGPASSWORD
        return 1
    fi

    if ! echo "$PASSWORD" | sudo -S -u postgres psql -d dialectic -c "CREATE EXTENSION IF NOT EXISTS pg_trgm; CREATE EXTENSION IF NOT EXISTS vector; ALTER DATABASE dialectic OWNER TO dwemer;" >/dev/null 2>&1; then
        print_warning "Failed to provision Dialectic PostgreSQL extensions."
        unset PGPASSWORD
        return 1
    fi

    schema_ready=$(psql -h localhost -U dwemer -d dialectic -tAc "SELECT 1 FROM information_schema.tables WHERE table_schema='public' AND table_name='eventlog' LIMIT 1" 2>/dev/null | tr -d '[:space:]')
    if [ "$schema_ready" != "1" ]; then
        if [ ! -f "$baseline" ]; then
            print_warning "Dialectic database baseline is missing: $baseline"
            unset PGPASSWORD
            return 1
        fi
        printf ">> Importing Dialectic database baseline...\n"
        if ! psql -h localhost -U dwemer -d dialectic -f "$baseline" >"$bootstrap_output" 2>&1; then
            print_warning "Failed to import the Dialectic database baseline. See $bootstrap_output"
            unset PGPASSWORD
            return 1
        fi
    fi

    printf ">> Running Dialectic database migrations and seed verification...\n"
    if ! php "$server_root/tools/bootstrap-database.php" >"$bootstrap_output" 2>&1; then
        mkdir -p "$server_root/log" >/dev/null 2>&1 || true
        cp "$bootstrap_output" "$server_root/log/db_update_runner.log" 2>/dev/null || true
        print_warning "Dialectic database bootstrap failed. See $server_root/log/db_update_runner.log"
        unset PGPASSWORD
        return 1
    fi

    rm -f "$bootstrap_output"
    unset PGPASSWORD
    print_success "Dialectic database is ready."
    return 0
}

# Optional selective server updates.
while [ $# -gt 0 ]; do
    case "$1" in
        --skip-herika)
            UPDATE_HERIKA=0
            ;;
        --skip-stobe)
            UPDATE_STOBE=0
            ;;
        --skip-dialectic)
            UPDATE_DIALECTIC=0
            ;;
        *)
            print_warning "Unknown option '$1' ignored"
            ;;
    esac
    shift
done

# Main title
printf "\n${BOLD}=======================================================${NC}\n"
printf "${BOLD}          DWEMER DYNAMICS SYSTEM UPDATE                ${NC}\n"
printf "${BOLD}=======================================================${NC}\n\n"

# Server update
if [ "$UPDATE_HERIKA" -eq 1 ]; then
    cd /var/www/html/HerikaServer
    BRANCH=$(git branch --show-current)
    print_header "UPDATING HERIKA SERVER" "$BRANCH"

    printf ">> Resetting repository...\n"
    git reset --hard HEAD
    printf ">> Pulling latest changes...\n"
    git pull
    # Set permissions for HerikaServer immediately after updating
    echo $PASSWORD | sudo -S chown -R dwemer:www-data /var/www/html/HerikaServer
    echo $PASSWORD | sudo -S chmod -R 775 /var/www/html/HerikaServer
    printf "${GREEN}[SUCCESS] HerikaServer updated successfully${NC}\n"
else
    print_warning "Skipping HerikaServer update by request"
fi

if [ "$UPDATE_STOBE" -eq 1 ]; then
    STOBE_INITIAL_INSTALL=0
    if ensure_stobe_repo_exists "stobe"; then
        cd /var/www/html/StobeServer || {
            print_warning "Could not access /var/www/html/StobeServer after setup."
            STOBE_SETUP_FAILED=1
        }

        if [ "${STOBE_SETUP_FAILED:-0}" -ne 1 ]; then
            if [ "$STOBE_INITIAL_INSTALL" -eq 0 ]; then
                BRANCH=$(git branch --show-current)
                print_header "UPDATING STOBE SERVER" "$BRANCH"
                printf ">> Resetting repository...\n"
                git reset --hard HEAD
                printf ">> Pulling latest changes...\n"
                git pull
            fi

            if [ "$STOBE_INITIAL_INSTALL" -eq 1 ]; then
                printf ">> Clearing seeded Stobe logs for initial install...\n"
                clear_stobe_initial_logs || print_warning "StobeServer initial install log reset was incomplete."
            fi

            # Set permissions for StobeServer
            echo $PASSWORD | sudo -S chown -R dwemer:www-data /var/www/html/StobeServer
            echo $PASSWORD | sudo -S chmod -R 775 /var/www/html/StobeServer
            if ensure_stobe_database; then
                printf "${GREEN}[SUCCESS] StobeServer updated successfully${NC}\n"
            else
                print_warning "StobeServer updated, but DB provisioning was incomplete."
            fi
        else
            print_warning "StobeServer setup failed; skipping remaining StobeServer update steps."
        fi
    else
        print_warning "StobeServer repository setup failed; skipping StobeServer update."
    fi
else
    print_warning "Skipping StobeServer update by request"
fi

if [ "$UPDATE_DIALECTIC" -eq 1 ]; then
    DIALECTIC_INITIAL_INSTALL=0
    if ensure_dialectic_repo_exists "dialectic"; then
        cd /var/www/html/DialecticServer || true
        if [ "$DIALECTIC_INITIAL_INSTALL" -eq 0 ]; then
            BRANCH=$(git branch --show-current)
            print_header "UPDATING DIALECTIC SERVER" "$BRANCH"
            printf ">> Resetting repository...\n"
            git reset --hard HEAD
            printf ">> Pulling latest changes...\n"
            git pull --ff-only
        fi

        ensure_dialectic_runtime_permissions || true
        if ensure_dialectic_database; then
            print_success "DialecticServer updated successfully"
        else
            DIALECTIC_UPDATE_FAILED=1
            print_warning "DialecticServer updated, but database provisioning was incomplete."
        fi
    else
        DIALECTIC_UPDATE_FAILED=1
        print_warning "DialecticServer repository setup failed; skipping DialecticServer update."
    fi
else
    print_warning "Skipping DialecticServer update by request"
fi

# Dwemer Dashboard update/install
if [ ! -d /var/www/html/Dwemer-Dashboard/.git ]; then
    print_header "INSTALLING DWEMER DASHBOARD"
    cd /var/www/html
    rm -rf /var/www/html/Dwemer-Dashboard
    printf ">> Cloning Dwemer Dashboard repository...\n"
    git clone https://github.com/Dwemer-Dynamics/Dwemer-Dashboard.git Dwemer-Dashboard
else
    cd /var/www/html/Dwemer-Dashboard
    BRANCH=$(git branch --show-current)
    print_header "UPDATING DWEMER DASHBOARD" "$BRANCH"
    printf ">> Resetting repository...\n"
    git reset --hard HEAD
    printf ">> Pulling latest changes...\n"
    git pull
fi

# Set permissions for Dwemer Dashboard
echo $PASSWORD | sudo -S chown -R dwemer:www-data /var/www/html/Dwemer-Dashboard
echo $PASSWORD | sudo -S chmod -R 775 /var/www/html/Dwemer-Dashboard
printf "${GREEN}[SUCCESS] Dwemer Dashboard updated successfully${NC}\n"

# MiniMe update
cd /home/dwemer/minime-t5
BRANCH=$(git branch --show-current)
print_header "UPDATING MINI-ME & TXT2VEC" "$BRANCH"

printf ">> Resetting repository...\n"
git reset --hard HEAD
printf ">> Pulling latest changes...\n"
XTTS_UPDATE_OK=1
if git fetch origin "$BRANCH"; then
    XTTS_CONFLICT_FILE="xtts_api_server/voice_management.py"
    if [ -f "$XTTS_CONFLICT_FILE" ] \
        && ! git ls-files --error-unmatch -- "$XTTS_CONFLICT_FILE" >/dev/null 2>&1 \
        && git cat-file -e "origin/${BRANCH}:${XTTS_CONFLICT_FILE}" 2>/dev/null; then
        XTTS_BACKUP_ROOT="/home/dwemer/xtts-api-server-update-backups/$(date -u '+%Y%m%d%H%M%S')"
        mkdir -p "$XTTS_BACKUP_ROOT/$(dirname "$XTTS_CONFLICT_FILE")"
        if mv "$XTTS_CONFLICT_FILE" "$XTTS_BACKUP_ROOT/$XTTS_CONFLICT_FILE"; then
            print_warning "Backed up conflicting local XTTS file to $XTTS_BACKUP_ROOT/$XTTS_CONFLICT_FILE"
        else
            print_warning "Failed to back up conflicting XTTS file: $XTTS_CONFLICT_FILE"
            XTTS_UPDATE_OK=0
        fi
    fi

    if [ "$XTTS_UPDATE_OK" -eq 1 ] && ! git merge --ff-only "origin/$BRANCH"; then
        XTTS_UPDATE_OK=0
    fi
else
    XTTS_UPDATE_OK=0
fi
if [ -x /home/dwemer/python-minime/bin/pip ]; then
    printf ">> Updating Python dependencies...\n"
    /home/dwemer/python-minime/bin/pip install -r requirements.txt
else
    print_warning "MiniMe virtual environment not found at /home/dwemer/python-minime; run the MiniMe component installer to install dependencies."
fi

# Set permissions for minime-t5
sudo chown -R dwemer:dwemer /home/dwemer/minime-t5
sudo chmod -R 755 /home/dwemer/minime-t5
printf "${GREEN}[SUCCESS] MiniMe & TXT2VEC updated successfully${NC}\n"

# MeloTTS update
cd /home/dwemer/MeloTTS
BRANCH=$(git branch --show-current)
print_header "UPDATING MELO-TTS" "$BRANCH"

printf ">> Resetting repository...\n"
git reset --hard HEAD
printf ">> Pulling latest changes...\n"
git pull

# Set permissions for MeloTTS
sudo chown -R dwemer:dwemer /home/dwemer/MeloTTS
sudo chmod -R 755 /home/dwemer/MeloTTS
printf "${GREEN}[SUCCESS] MeloTTS updated successfully${NC}\n"

# LocalWhisper update
cd /home/dwemer/remote-faster-whisper
BRANCH=$(git branch --show-current)
print_header "UPDATING LOCALWHISPER" "$BRANCH"

# Check current remote URL
CURRENT_REMOTE=$(git config --get remote.origin.url)
TARGET_REMOTE="https://github.com/abeiro/remote-faster-whisper.git"

# Set the correct remote if needed
if [ "$CURRENT_REMOTE" != "$TARGET_REMOTE" ]; then
    print_warning "Setting remote to $TARGET_REMOTE"
    git remote set-url origin $TARGET_REMOTE
fi

printf ">> Resetting repository...\n"
git reset --hard HEAD
printf ">> Pulling latest changes...\n"
git pull

# Set permissions for LocalWhisper
sudo chown -R dwemer:dwemer /home/dwemer/remote-faster-whisper
sudo chmod -R 755 /home/dwemer/remote-faster-whisper
printf "${GREEN}[SUCCESS] LocalWhisper updated successfully${NC}\n"

# Piper TTS update/setup
# Check if piper directory exists and has README.md
if [ ! -d "/home/dwemer/piper" ] || [ ! -f "/home/dwemer/piper/README.md" ]; then
    print_header "SETTING UP PIPER TTS"
    print_warning "Piper TTS not found or incomplete. Cloning repository..."
    
    # Create directory if it doesn't exist
    if [ ! -d "/home/dwemer/piper" ]; then
        mkdir -p /home/dwemer/piper
    fi
    
    cd /home/dwemer
    # Remove directory if it exists but doesn't have README.md (incomplete clone)
    if [ -d "piper" ] && [ ! -f "piper/README.md" ]; then
        rm -rf piper
    fi
    
    printf ">> Cloning Piper TTS repository...\n"
    git clone -b main https://github.com/Dwemer-Dynamics/Piper-TTS-CHIM.git piper
    
    cd /home/dwemer/piper
else
    # Directory exists with README.md, so update it
    cd /home/dwemer/piper
    BRANCH=$(git branch --show-current)
    print_header "UPDATING PIPER TTS" "$BRANCH"
    
    printf ">> Resetting repository...\n"
    git reset --hard HEAD --quiet
    printf ">> Pulling latest changes...\n"
    git pull
fi

# Set permissions for Piper TTS
sudo chown -R dwemer:dwemer /home/dwemer/piper
sudo chmod -R 755 /home/dwemer/piper
printf "${GREEN}[SUCCESS] Piper TTS updated successfully${NC}\n"

# XTTSv2 server update
cd /home/dwemer/xtts-api-server
BRANCH=$(git branch --show-current)
print_header "UPDATING CHIM XTTS" "$BRANCH"

# Backup speakers folder if it exists
if [ -d "speakers" ]; then
    print_warning "Backing up speakers folder..."
    cp -r speakers speakers.backup
fi

printf ">> Resetting repository...\n"
git reset --hard HEAD
printf ">> Pulling latest changes...\n"
git pull

# Restore speakers folder if backup exists
if [ -d "speakers.backup" ]; then
    print_warning "Restoring speakers folder..."
    cp -r speakers.backup/* speakers/ 2>/dev/null || true
    rm -rf speakers.backup
fi

# Set permissions for XTTS
sudo chown -R dwemer:dwemer /home/dwemer/xtts-api-server
sudo chmod -R 755 /home/dwemer/xtts-api-server
if [ "$XTTS_UPDATE_OK" -eq 1 ]; then
    printf "${GREEN}[SUCCESS] CHIM XTTS updated successfully${NC}\n"
else
    COMPONENT_UPDATE_FAILED=1
    print_warning "CHIM XTTS update failed. The existing installation was retained."
fi

