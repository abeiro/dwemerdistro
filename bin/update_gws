printf "${GREEN}[SUCCESS] System permissions updated${NC}\n"

# Install netcat only when missing; apt is slow and should not run on every update.
if ! command -v nc >/dev/null 2>&1; then
    sudo apt-get update && sudo apt-get -y install netcat-openbsd
else
    printf "${GREEN}[SUCCESS] netcat already installed${NC}\n"
fi

# Final message
if [ "$DIALECTIC_UPDATE_FAILED" -ne 0 ] || [ "$COMPONENT_UPDATE_FAILED" -ne 0 ]; then
    printf "\n${BOLD}=======================================================${NC}\n"
    printf "${BOLD}${RED}              UPDATE COMPLETED WITH ERRORS            ${NC}\n"
    printf "${BOLD}=======================================================${NC}\n\n"
    exit 1
fi

printf "\n${BOLD}=======================================================${NC}\n"
printf "${BOLD}${GREEN}                ALL UPDATES COMPLETED!               ${NC}\n"
