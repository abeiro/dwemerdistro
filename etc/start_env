check_port() {
    local port=$1
    local retries=30
    local wait_time=2
    local attempt=1

    while (( attempt <= retries )); do
        if netstat -lNnp | grep ":$port" &>/dev/null; then
            echo " started "
            return 0
        else
            echo -ne "."
            if (( attempt < retries )); then
                sleep $wait_time
            fi
        fi
        ((attempt++))
    done

    echo "not started"
    return 1
}

