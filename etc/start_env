read_tts_service_port() {
    local port_file="$1"
    local fallback="$2"
    local value=""

    if [ -f "$port_file" ]; then
        value="$(tr -d '[:space:]' < "$port_file")"
    fi
    case "$value" in
        ''|*[!0-9]*) value="$fallback" ;;
    esac
    printf '%s\n' "$value"
}

