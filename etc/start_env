        "service.log"
        "log_run_agent.log"
        "chim.log"
        "manager.log"
        "monitor.log"
    )

    if [ ! -d "$herika_root" ]; then
        echo "Skipping HerikaServer log permission bootstrap (HerikaServer not installed)."
        return 0
    fi

    mkdir -p "$log_dir" >/dev/null 2>&1 || true
    chown -R dwemer:www-data "$log_dir" >/dev/null 2>&1 || true
    chmod 2775 "$log_dir" >/dev/null 2>&1 || true

    for log_file in "${log_files[@]}"; do
        local full_path="${log_dir}/${log_file}"
        touch "$full_path" >/dev/null 2>&1 || true
        chown dwemer:www-data "$full_path" >/dev/null 2>&1 || true
        chmod 664 "$full_path" >/dev/null 2>&1 || true
    done
}

