#!/bin/bash

/usr/local/bin/print_logo

# Load CUDA configuration if it exists (will not be overwritten by updates)
if [ -f "/home/dwemer/.cuda_config" ]; then
    source /home/dwemer/.cuda_config
fi

# Clean tmp
find /tmp -type f -mtime +7 -delete 
find /tmp/ -type d -mtime +7 -exec \rm -fr {} \; &>/dev/null

check_port() {
    local port=$1
    local retries=30
    local wait_time=2
    local attempt=1

    while (( attempt <= retries )); do
        if netstat -lNnp | grep ":$port" &>/dev/null; then
            echo " started "
            return 0
        else
            echo -ne "."
            if (( attempt < retries )); then
                sleep $wait_time
            fi
        fi
        ((attempt++))
    done

    echo "not started"
    return 1
}

# Get both WSL2 and Windows host IPs using enhanced get_ip script
wsl_ip=$(/usr/local/bin/get_ip --wsl)
host_ip=$(/usr/local/bin/get_ip --host)

ensure_stobe_apache_vhost() {
    local ports_conf="/etc/apache2/ports.conf"
    local stobe_conf="/etc/apache2/sites-available/stobe.conf"

    # Ensure Apache listens on 8083 for StobeServer.
    if ! grep -Eq '^[[:space:]]*Listen[[:space:]]+0\.0\.0\.0:8083([[:space:]]|$)' "$ports_conf"; then
        echo "Listen 0.0.0.0:8083" >> "$ports_conf"
    fi

    # Ensure StobeServer vhost keeps /StobeServer endpoint on port 8083.
    cat > "$stobe_conf" << 'EOF'
<VirtualHost *:8083>
	ServerAdmin webmaster@localhost
	DocumentRoot /var/www/html
	Alias /StobeServer /var/www/html/StobeServer

	<Directory /var/www/html>
		Options -Indexes +FollowSymLinks
		AllowOverride All
		Require all granted
	</Directory>

	<Directory /var/www/html/StobeServer>
		Options -Indexes +FollowSymLinks
		AllowOverride All
		Require all granted
	</Directory>

	ErrorLog ${APACHE_LOG_DIR}/stobe_error.log
	CustomLog ${APACHE_LOG_DIR}/stobe_access.log combined

	LimitRequestLine 65535
</VirtualHost>
EOF

    a2ensite stobe.conf >/dev/null 2>&1 || true
}

ensure_stobe_database() {
    local schema_path="/var/www/html/StobeServer/data/schema.sql"
    local db_exists=""
    local schema_ready=""

    if [ ! -d /var/www/html/StobeServer ]; then
        echo "Skipping StobeServer DB bootstrap (StobeServer not installed)."
        return 0
    fi

    export PGPASSWORD=dwemer

    db_exists=$(psql -h localhost -U dwemer -tAc "SELECT 1 FROM pg_database WHERE datname = 'stobe' LIMIT 1" 2>/dev/null | tr -d '[:space:]')
    if [ "$db_exists" != "1" ]; then
        echo "Creating StobeServer database..."
        if ! createdb -h localhost -U dwemer stobe >/dev/null 2>&1; then
            echo "WARNING: Failed to create stobe database."
            unset PGPASSWORD
            return 1
        fi
    fi

    if [ ! -f "$schema_path" ]; then
        echo "WARNING: StobeServer schema file missing at $schema_path"
        unset PGPASSWORD
        return 1
    fi

    schema_ready=$(psql -h localhost -U dwemer -d stobe -tAc "SELECT 1 FROM information_schema.tables WHERE table_schema='public' AND table_name='general_settings' LIMIT 1" 2>/dev/null | tr -d '[:space:]')
    if [ "$schema_ready" != "1" ]; then
        echo "Applying StobeServer schema..."
        if ! psql -h localhost -U dwemer -d stobe -f "$schema_path" >/dev/null 2>&1; then
            echo "WARNING: Failed to apply StobeServer schema."
            unset PGPASSWORD
            return 1
        fi
    fi

    if [ -f /var/www/html/StobeServer/debug/run_db_updates.php ]; then
        if ! php /var/www/html/StobeServer/debug/run_db_updates.php >/dev/null 2>&1; then
            echo "WARNING: StobeServer DB update trigger failed. Check StobeServer logs."
            unset PGPASSWORD
            return 1
        fi
    fi

    echo "StobeServer database ready."
    unset PGPASSWORD
    return 0
}

ensure_stobe_apache_vhost

# Start Apache/PHP server
echo "Starting Apache/PHP/PGSQL Server"
/etc/init.d/apache2 restart &>/dev/null
/etc/init.d/postgresql restart

if ! ensure_stobe_database; then
    echo "WARNING: StobeServer may not be fully initialized."
fi

# Create symbolic link for Apache error log if it doesn't exist
if [ ! -e "/var/www/html/HerikaServer/log/apache_error.log" ]; then
  mkdir -p /var/www/html/HerikaServer/log/
  ln -sf /var/log/apache2/error.log /var/www/html/HerikaServer/log/apache_error.log
fi

if [ -f  "/home/dwemer/minime-t5/start.sh" ]; then
	echo -ne  "Starting Minime-T5/TXT2VEC service "
	su dwemer -c /home/dwemer/minime-t5/start.sh
	check_port 8082
else
	echo "Skipping Minime-T5/TXT2VEC service (not enabled)"
	L_MINIME=1
fi

if [ -f  "/home/dwemer/mimic3/start.sh" ]; then
	echo -ne  "Starting Mimic3 TTS "
	su dwemer -c /home/dwemer/mimic3/start.sh
	check_port 59125
else
	echo "Skipping Mimic3 TTS (not enabled)"
	L_MIMIC=1
fi

if [ -f  "/home/dwemer/MeloTTS/start.sh" ]; then
	echo -ne  "Starting MeloTTS "
	su dwemer -c /home/dwemer/MeloTTS/start.sh
	check_port 8084
else
	echo "Skipping MeloTTS (not enabled)"
	L_MELOTTS=1
fi

if [ -f /home/dwemer/parakeet-api-server/start.sh ];then
	echo -ne  "Starting Parakeet "
	su dwemer -c /home/dwemer/parakeet-api-server/start.sh
	check_port 8022
else
	echo "Skipping Parakeet (not enabled)"
	L_PARAKEET=1
fi

if [ -f /home/dwemer/chatterbox/start.sh ];then
	echo -ne  "Starting Chatterbox"
	su dwemer -c /home/dwemer/chatterbox/start.sh
	check_port 8022
else
	echo "Skipping Chatterbox (not enabled)"
	L_CHATTERBOX=1
fi

if [ -f /home/dwemer/pocket-tts/start.sh ];then
	echo -ne  "Starting pocket-tts"
	su dwemer -c /home/dwemer/pocket-tts/start.sh
	check_port 8020
else
	echo "Skipping pocket-tts (not enabled)"
	L_POCKETTTS=1
fi

if [ -f "/home/dwemer/piper/cuda-keyring_1.1-1_all.deb" ]; then 

    if [ -f  "/home/dwemer/piper/start.sh" ]; then
        echo -ne  "Starting Piper-TTS "
        su dwemer -c /home/dwemer/piper/start.sh
        check_port 5000
    else
        echo "Skipping Piper-TTS (not enabled)"
        L_PIPERTTS=1
    fi
else
    echo "Skipping Piper-TTS (not enabled)"
    L_PIPERTTS=1
fi

if [ -f  "/home/dwemer/remote-faster-whisper/config.yaml" ]; then
	echo -ne  "Starting LocalWhisper Server "
	su dwemer -c "/home/dwemer/remote-faster-whisper/start.sh"
	check_port 9876
else
	L_WHISPER=1
	echo  "Skipping LocalWhisper Server (not enabled)"
fi

if [ -f  "/home/dwemer/xtts-api-server/start.sh" ]; then
	echo -ne  "Starting CHIM XTTS server"
	su dwemer -c "/home/dwemer/xtts-api-server/start.sh"
	check_port 8020
else
	echo  "Skipping CHIM XTTS server (not enabled)"
	L_XTTSV2=1
fi

# Check if MCP is enabled (default: enabled if flag file missing)
MCP_ENABLED=1
if [ -f "/home/dwemer/.mcp_enabled" ]; then
	MCP_ENABLED=$(cat /home/dwemer/.mcp_enabled 2>/dev/null || echo "1")
fi

if [ "$MCP_ENABLED" = "1" ] && [ -f "/home/dwemer/CHIM-MCP/start.sh" ]; then
	echo -ne  "Starting CHIM MCP Server "
	su dwemer -c /home/dwemer/CHIM-MCP/start.sh
	check_port 3100
elif [ "$MCP_ENABLED" = "1" ] && [ -f "/home/dwemer/chim-mcp-server/start.sh" ]; then
	# Backward compatibility for older installs.
	echo -ne  "Starting CHIM MCP Server (legacy path) "
	su dwemer -c /home/dwemer/chim-mcp-server/start.sh
	check_port 3100
else
	if [ "$MCP_ENABLED" != "1" ]; then
		echo "Skipping CHIM MCP Server (disabled by user)"
	else
		echo "Skipping CHIM MCP Server (not enabled)"
	fi
	L_MCPSERVER=1
fi

# Save IPs to PostgreSQL database after all services are started
export PGPASSWORD=dwemer

# Wait for PostgreSQL to be fully ready
sleep 2

# Check if database connection works and create/update IP records
psql_result=$(psql -h localhost -U dwemer -d dwemer -t -c "SELECT 1;" 2>/dev/null | tr -d ' \n')
if [ "$psql_result" = "1" ]; then
    # Create conf_opts table if it doesn't exist
    psql -h localhost -U dwemer -d dwemer -c "
    CREATE TABLE IF NOT EXISTS conf_opts (
        id VARCHAR(255) PRIMARY KEY,
        value TEXT
    );" &>/dev/null
    
    # Insert/Update WSL IP
    psql -h localhost -U dwemer -d dwemer -c "
    INSERT INTO conf_opts (id, value) 
    VALUES ('Network/WSL_IP', '$wsl_ip') 
    ON CONFLICT (id) 
    DO UPDATE SET value = EXCLUDED.value;" &>/dev/null
    
    # Insert/Update Windows Host IP  
    psql -h localhost -U dwemer -d dwemer -c "
    INSERT INTO conf_opts (id, value) 
    VALUES ('Network/HOST_IP', '$host_ip') 
    ON CONFLICT (id) 
    DO UPDATE SET value = EXCLUDED.value;" &>/dev/null
    
    echo "Network IPs saved to database successfully."
fi

unset PGPASSWORD

ipaddress=$(/usr/local/bin/get_ip)
cat << EOF
=======================================
AIAgent.ini Network Settings:
Windows Host IP: $host_ip 
WSL2 Internal IP: $wsl_ip 
HerikaServer: http://$ipaddress:8081/HerikaServer
StobeServer: http://$ipaddress:8083/StobeServer

Running Components:
EOF

if [ -z "$L_MINIME" ]; then
	echo Minime-T5/TXT2VEC API: http://$ipaddress:8082
fi

if [ -z "$L_WHISPER" ]; then
	echo LocalWhisper API: http://$ipaddress:9876
fi

if [ -z "$L_XTTSV2" ]; then
	echo CHIM XTTS API: http://$ipaddress:8020
fi

if [ -z "$L_MIMIC" ]; then
	echo Mimic3 API: http://$ipaddress:59125
fi

if [ -z "$L_MELOTTS" ]; then
	echo MelotTTS API: http://$ipaddress:8084
fi

if [ -z "$L_PIPERTTS" ]; then
	echo Piper-TTS API: http://$ipaddress:5000
fi

if [ -z "$L_PARAKEET" ]; then
	echo Parakeet API: http://$ipaddress:8022
fi

if [ -z "$L_CHATTERBOX" ]; then
	echo Chatterbox API: http://$ipaddress:8020
fi

if [ -z "$L_POCKETTTS" ]; then
	echo PockeTTS API: http://$ipaddress:8020
fi

if [ -z "$L_MCPSERVER" ]; then
	echo CHIM MCP Server: http://$ipaddress:3100
fi

explorer.exe http://$ipaddress:8081/Dwemer-Dashboard/index.php &>/dev/null&

echo "Press Enter to shutdown DwemerDistro"
read

killall -15 -u dwemer

/etc/init.d/apache2 stop
/etc/init.d/postgresql stop

echo "DwemerDistro has stopped running"

