ensure_stobe_database() {
    local schema_path="/var/www/html/StobeServer/data/schema.sql"
    local db_exists=""
    local schema_ready=""

    if [ ! -d /var/www/html/StobeServer ]; then
        echo "Skipping StobeServer DB bootstrap (StobeServer not installed)."
        return 0
    fi

    export PGPASSWORD=dwemer

    db_exists=$(psql -h localhost -U dwemer -tAc "SELECT 1 FROM pg_database WHERE datname = 'stobe' LIMIT 1" 2>/dev/null | tr -d '[:space:]')
    if [ "$db_exists" != "1" ]; then
        echo "Creating StobeServer database..."
        if ! createdb -h localhost -U dwemer stobe >/dev/null 2>&1; then
            echo "WARNING: Failed to create stobe database."
            unset PGPASSWORD
            return 1
        fi
    fi

    if [ ! -f "$schema_path" ]; then
        echo "WARNING: StobeServer schema file missing at $schema_path"
        unset PGPASSWORD
        return 1
    fi

    schema_ready=$(psql -h localhost -U dwemer -d stobe -tAc "SELECT 1 FROM information_schema.tables WHERE table_schema='public' AND table_name='general_settings' LIMIT 1" 2>/dev/null | tr -d '[:space:]')
    if [ "$schema_ready" != "1" ]; then
        echo "Applying StobeServer schema..."
        if ! psql -h localhost -U dwemer -d stobe -f "$schema_path" >/dev/null 2>&1; then
            echo "WARNING: Failed to apply StobeServer schema."
            unset PGPASSWORD
            return 1
        fi
    fi

    if [ -f /var/www/html/StobeServer/debug/run_db_updates.php ]; then
        local stobe_db_update_log="/var/www/html/StobeServer/log/db_update_runner.log"
        local stobe_db_update_tmp="/tmp/stobe_db_update_runner.out"
        if ! php /var/www/html/StobeServer/debug/run_db_updates.php >"$stobe_db_update_tmp" 2>&1; then
            mkdir -p /var/www/html/StobeServer/log >/dev/null 2>&1 || true
            {
                printf "\n[%s] start_env: run_db_updates.php failed\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
                cat "$stobe_db_update_tmp"
            } >> "$stobe_db_update_log"
            echo "WARNING: StobeServer DB update trigger failed. See $stobe_db_update_log"
            rm -f "$stobe_db_update_tmp"
            unset PGPASSWORD
            return 1
        fi
        rm -f "$stobe_db_update_tmp"
    fi

    echo "StobeServer database ready."
    unset PGPASSWORD
    return 0
}

ensure_dialectic_database() {
    local server_root="/var/www/html/DialecticServer"
    local baseline="$server_root/data/database_default.sql"
    local db_exists=""
    local db_encoding=""
    local schema_ready=""
    local bootstrap_output="/tmp/dialectic_startup_database_bootstrap.out"

    if [ ! -d "$server_root" ]; then
        echo "Skipping DialecticServer DB bootstrap (DialecticServer not installed)."
        return 0
    fi

    export PGPASSWORD=dwemer
    : > "$bootstrap_output"
    if ! db_exists=$(psql -h localhost -U dwemer -d dwemer -X -tAc "SELECT 1 FROM pg_database WHERE datname = 'dialectic' LIMIT 1" 2>>"$bootstrap_output"); then
        printf '\nApplication database catalog probe failed; trying the PostgreSQL service account.\n' >> "$bootstrap_output"
        if ! db_exists=$(sudo -u postgres psql -d template1 -X -tAc "SELECT 1 FROM pg_database WHERE datname = 'dialectic' LIMIT 1" 2>>"$bootstrap_output"); then
            mkdir -p "$server_root/log" >/dev/null 2>&1 || true
            cp "$bootstrap_output" "$server_root/log/db_update_runner.log" 2>/dev/null || true
            echo "WARNING: Failed to inspect the Dialectic database. See $server_root/log/db_update_runner.log"
            tail -n 8 "$bootstrap_output" | sed 's/^/  /'
            unset PGPASSWORD
            return 1
        fi
    fi
    db_exists=$(printf '%s' "$db_exists" | tr -d '[:space:]')
    if [ "$db_exists" != "1" ]; then
        echo "Creating DialecticServer database..."
        if ! sudo -u postgres createdb --maintenance-db=template1 --owner=dwemer --encoding=UTF8 --locale=C --template=template0 dialectic >"$bootstrap_output" 2>&1; then
            mkdir -p "$server_root/log" >/dev/null 2>&1 || true
            cp "$bootstrap_output" "$server_root/log/db_update_runner.log" 2>/dev/null || true
            echo "WARNING: Failed to create dialectic database. See $server_root/log/db_update_runner.log"
            unset PGPASSWORD
            return 1
        fi
    fi

    : > "$bootstrap_output"
    if ! db_encoding=$(psql -h localhost -U dwemer -d dwemer -X -tAc "SELECT pg_encoding_to_char(encoding) FROM pg_database WHERE datname = 'dialectic'" 2>>"$bootstrap_output"); then
        printf '\nApplication database encoding probe failed; trying the PostgreSQL service account.\n' >> "$bootstrap_output"
        if ! db_encoding=$(sudo -u postgres psql -d template1 -X -tAc "SELECT pg_encoding_to_char(encoding) FROM pg_database WHERE datname = 'dialectic'" 2>>"$bootstrap_output"); then
            mkdir -p "$server_root/log" >/dev/null 2>&1 || true
            cp "$bootstrap_output" "$server_root/log/db_update_runner.log" 2>/dev/null || true
            echo "WARNING: Failed to inspect the Dialectic database encoding. See $server_root/log/db_update_runner.log"
            tail -n 8 "$bootstrap_output" | sed 's/^/  /'
            unset PGPASSWORD
            return 1
        fi
    fi
    db_encoding=$(printf '%s' "$db_encoding" | tr -d '[:space:]')
    if [ "$db_encoding" != "UTF8" ]; then
        echo "WARNING: Dialectic database uses unsupported encoding '${db_encoding:-unknown}'. Run the DwemerDistro updater to migrate it before startup."
        unset PGPASSWORD
        return 1
    fi

    if ! sudo -u postgres psql -d dialectic -c "CREATE EXTENSION IF NOT EXISTS pg_trgm; CREATE EXTENSION IF NOT EXISTS vector; ALTER DATABASE dialectic OWNER TO dwemer;" >/dev/null 2>&1; then
        echo "WARNING: Failed to provision Dialectic PostgreSQL extensions."
        unset PGPASSWORD
        return 1
    fi

    schema_ready=$(psql -h localhost -U dwemer -d dialectic -tAc "SELECT 1 FROM information_schema.tables WHERE table_schema='public' AND table_name='eventlog' LIMIT 1" 2>/dev/null | tr -d '[:space:]')
    if [ "$schema_ready" != "1" ]; then
        if [ ! -f "$baseline" ] || ! psql -h localhost -U dwemer -d dialectic -f "$baseline" >"$bootstrap_output" 2>&1; then
            echo "WARNING: Failed to apply the Dialectic database baseline. See $bootstrap_output"
            unset PGPASSWORD
            return 1
        fi
    fi

    if ! php "$server_root/tools/bootstrap-database.php" >"$bootstrap_output" 2>&1; then
        mkdir -p "$server_root/log" >/dev/null 2>&1 || true
        cp "$bootstrap_output" "$server_root/log/db_update_runner.log" 2>/dev/null || true
        echo "WARNING: Dialectic database bootstrap failed. See $server_root/log/db_update_runner.log"
        unset PGPASSWORD
        return 1
    fi

    rm -f "$bootstrap_output"
    unset PGPASSWORD
    echo "DialecticServer database ready."
    return 0
}

dialectic_processor_ready() {
    local attempt
    for attempt in {1..10}; do
        if nc -z 127.0.0.1 12347 >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.15
    done
    return 1
}

ensure_dialectic_runtime_permissions() {
    local helper="/usr/local/bin/ensure_dialectic_runtime_permissions"

    if [ ! -d /var/www/html/DialecticServer ]; then
        return 0
    fi

    if [ ! -x "$helper" ]; then
        echo "WARNING: DialecticServer permission helper is unavailable."
        return 1
    fi

    if ! "$helper" /var/www/html/DialecticServer; then
        echo "WARNING: DialecticServer runtime permission repair failed."
        return 1
    fi

    return 0
}

collect_dialectic_process_tree() {
    local parent_pid="$1"
    local child_pid

    while read -r child_pid; do
        [ -n "$child_pid" ] && collect_dialectic_process_tree "$child_pid"
    done < <(pgrep -P "$parent_pid" 2>/dev/null || true)

    echo "$parent_pid"
}

stop_stale_dialectic_runtime() {
    local start_script="$1"
    local root_pid pid
    local -a process_ids=()
    declare -A seen=()

    while read -r root_pid; do
        [ -n "$root_pid" ] || continue
        while read -r pid; do
            if [ -n "$pid" ] && [ -z "${seen[$pid]+x}" ]; then
                seen[$pid]=1
                process_ids+=("$pid")
            fi
        done < <(collect_dialectic_process_tree "$root_pid")
    done < <(pgrep -f "^bash $start_script$" 2>/dev/null || true)

    if [ "${#process_ids[@]}" -eq 0 ]; then
        return 0
    fi

    echo "Stopping stale DialecticServer background processor..."
    kill -TERM "${process_ids[@]}" 2>/dev/null || true
    sleep 1

    for pid in "${process_ids[@]}"; do
        if kill -0 "$pid" 2>/dev/null; then
            kill -KILL "$pid" 2>/dev/null || true
        fi
    done

    rm -f /tmp/dialectic_background_processor.lock
}

ensure_dialectic_runtime() {
    local server_root="/var/www/html/DialecticServer"
    local start_script="$server_root/service/start.sh"

    if [ ! -f "$start_script" ]; then
        return 0
    fi

    mkdir -p "$server_root/log" "$server_root/soundcache" "$server_root/uploads"
    chown -R dwemer:www-data "$server_root/log" "$server_root/soundcache" "$server_root/uploads" >/dev/null 2>&1 || true
    chmod 2775 "$server_root/log" "$server_root/soundcache" "$server_root/uploads" >/dev/null 2>&1 || true

    if ! dialectic_processor_ready; then
        stop_stale_dialectic_runtime "$start_script"
        echo "Starting DialecticServer background processor..."
        su dwemer -c "nohup bash '$start_script' >/dev/null 2>&1 </dev/null &"
    fi

    if dialectic_processor_ready; then
        echo "DialecticServer background processor ready."
    else
        echo "WARNING: DialecticServer background processor is not listening on port 12347."
    fi
}

ensure_herika_log_permissions() {
